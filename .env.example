# Cashmere Agent SDK - Environment Variables
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env to version control

# EVM private key (hex, with or without 0x prefix)
EVM_PRIVATE_KEY=

# Solana private key (base58 or hex format)
SOLANA_PRIVATE_KEY=

# Aptos private key (hex, with or without 0x prefix)
APTOS_PRIVATE_KEY=

# Sui private key (hex, with or without 0x prefix)
SUI_PRIVATE_KEY=

# Optional: Custom RPC URLs (defaults to public RPCs if not set)
# EVM_RPC_URL=
# SOLANA_RPC_URL=
# APTOS_RPC_URL=
# SUI_RPC_URL=

# Optional: Custom Gas API URL (default: https://gas.cashmere.exchange)
# GAS_API_URL=
